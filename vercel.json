{
    "regions": [
        "hnd1"
    ],
    "buildCommand": "npm install && npm run build && composer install && php artisan config:clear && php artisan config:cache",
    "builds": [
        {
            "src": "/api/index.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/assets/(.*)",
            "dest": "/public/build/assets/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "うみもぐら",
        "APP_TIMEZONE": "Asia/Tokyo",
        "APP_LOCALE": "ja",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "5432",
        "DB_DATABASE": "itoshimadb",
        "DB_USERNAME": "itoshima",
        "DB_PASSWORD": "itoshima",
        "CACHE_DRIVER": "array",
        "CACHE_STORE": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "SESSION_COOKIE": "ordering_session",
        "VIEW_COMPILED_PATH": "/tmp",
        "ORDERING_PREFIX": "",
        "APP_DEBUG": "true"
    }
}